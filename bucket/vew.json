{
    "version": "0.6.0",
    "description": "vew -- a browser, with an agent built in.",
    "homepage": "https://vew.sh",
    "license": {
        "identifier": "Proprietary",
        "url": "https://vew.sh"
    },
    "architecture": {
        "64bit": {
            "url": "https://downloads.vew.sh/vew-win32-x64-0.6.0.zip",
            "hash": "46e67c8d1eec37486def5fedf82bbb66bfa1621de1badafdc770e8ea9a61bab1"
        },
        "arm64": {
            "url": "https://downloads.vew.sh/vew-win32-arm64-0.6.0.zip",
            "hash": "0d445a46762fa89adb78caa522610734ddbacdde2a29c7cc933c019dd5ecff8c"
        }
    },
    "bin": [
        "vew.cmd"
    ],
    "shortcuts": [
        [
            "vew.exe",
            "vew"
        ]
    ],
    "pre_uninstall": [
        "if (Test-Path \"$dir\\vew.exe\") { Start-Process -FilePath \"$dir\\vew.exe\" -ArgumentList '--unregister-browser' -Wait }"
    ],
    "checkver": {
        "url": "https://vew.sh/version-windows.json",
        "jsonpath": "$.version"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://downloads.vew.sh/vew-win32-x64-$version.zip"
            },
            "arm64": {
                "url": "https://downloads.vew.sh/vew-win32-arm64-$version.zip"
            }
        }
    }
}
