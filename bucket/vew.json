{
    "version": "0.1.0",
    "description": "vew -- a browser, with an agent built in.",
    "homepage": "https://vew.sh",
    "license": {
        "identifier": "Proprietary",
        "url": "https://vew.sh"
    },
    "architecture": {
        "64bit": {
            "url": "https://downloads.vew.sh/vew-win32-x64-0.1.0.zip",
            "hash": "1ea9da1febcab5c64571027c1624c206ea6ac7a002784fbbdb6567aa77f77af4"
        },
        "arm64": {
            "url": "https://downloads.vew.sh/vew-win32-arm64-0.1.0.zip",
            "hash": "537c406ba8b1cbe8ee5603988104a42fe25c7c09b4223fd7a6722f4a1f0c07f0"
        }
    },
    "bin": [
        "vew.cmd"
    ],
    "shortcuts": [
        [
            "vew.exe",
            "vew"
        ]
    ],
    "pre_uninstall": [
        "if (Test-Path \"$dir\\vew.exe\") { Start-Process -FilePath \"$dir\\vew.exe\" -ArgumentList '--unregister-browser' -Wait }"
    ],
    "checkver": {
        "url": "https://vew.sh/version-windows.json",
        "jsonpath": "$.version"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://downloads.vew.sh/vew-win32-x64-$version.zip"
            },
            "arm64": {
                "url": "https://downloads.vew.sh/vew-win32-arm64-$version.zip"
            }
        }
    }
}
