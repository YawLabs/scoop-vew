            "vew"
        ]
    ],
    "pre_uninstall": [
        "if (Test-Path \"$dir\\vew.exe\") { Start-Process -FilePath \"$dir\\vew.exe\" -ArgumentList '--unregister-browser' -Wait }"
    ],
    "checkver": {
        "url": "https://vew.sh/version-windows.json",
        "jsonpath": "$.version"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://downloads.vew.sh/vew-win32-x64-$version.zip"
            },
            "arm64": {
                "url": "https://downloads.vew.sh/vew-win32-arm64-$version.zip"
            }
        }
    }
}
