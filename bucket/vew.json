{
    "version": "0.3.0",
    "description": "vew -- a browser, with an agent built in.",
    "homepage": "https://vew.sh",
    "license": {
        "identifier": "Proprietary",
        "url": "https://vew.sh"
    },
    "architecture": {
        "64bit": {
            "url": "https://downloads.vew.sh/vew-win32-x64-0.3.0.zip",
            "hash": "4ad7786a9ddd70cc995e625c8190b4a8360f894d315126cbb1b25333370e51b6"
        },
        "arm64": {
            "url": "https://downloads.vew.sh/vew-win32-arm64-0.3.0.zip",
