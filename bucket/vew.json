{
    "version": "0.4.0",
    "description": "vew -- a browser, with an agent built in.",
    "homepage": "https://vew.sh",
    "license": {
        "identifier": "Proprietary",
        "url": "https://vew.sh"
    },
    "architecture": {
        "64bit": {
            "url": "https://downloads.vew.sh/vew-win32-x64-0.4.0.zip",
            "hash": "89cadad784bc2ff3178b229b39b50cb91a48469a58987fe63ecef059f1aec098"
        },
        "arm64": {
            "url": "https://downloads.vew.sh/vew-win32-arm64-0.4.0.zip",
            "hash": "7c3fefcdc8e7b8172d1caca80f5475bd8db10649f822429d228628ba95b58dec"
        }
    },
    "bin": [
        "vew.cmd"
    ],
    "shortcuts": [
        [
            "vew.exe",
            "vew"
        ]
    ],
    "pre_uninstall": [
        "if (Test-Path \"$dir\\vew.exe\") { Start-Process -FilePath \"$dir\\vew.exe\" -ArgumentList '--unregister-browser' -Wait }"
    ],
    "checkver": {
        "url": "https://vew.sh/version-windows.json",
        "jsonpath": "$.version"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://downloads.vew.sh/vew-win32-x64-$version.zip"
            },
            "arm64": {
                "url": "https://downloads.vew.sh/vew-win32-arm64-$version.zip"
            }
        }
    }
}
